# Created by Kiro - Production Environment Configuration
# Copy this file to .env and fill in your actual values

# API Configuration
EXPO_PUBLIC_API_BASE_URL=http://103.194.228.68:3552/v1/api/

# Firebase Configuration (Optional)
EXPO_PUBLIC_FIREBASE_API_KEY=your_firebase_api_key_here
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=your_firebase_auth_domain_here

# AWS S3 Configuration (Media Storage)
EXPO_PUBLIC_AWS_ACCESS_KEY_ID=your_aws_access_key_here
EXPO_PUBLIC_AWS_SECRET_ACCESS_KEY=your_aws_secret_key_here
EXPO_PUBLIC_AWS_REGION=ap-south-1
EXPO_PUBLIC_AWS_S3_BUCKET=your_s3_bucket_name_here

# FFmpeg Configuration
EXPO_PUBLIC_FFMPEG_ENABLED=true

# Environment
EXPO_PUBLIC_ENV=production

# App Version
EXPO_PUBLIC_APP_VERSION=1.0.0
