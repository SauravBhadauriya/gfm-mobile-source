# Created by Kiro - Production Environment Configuration
# Copy this file to .env and fill in your actual values

# API Configuration
# Backend server URL - Update with your production server
EXPO_PUBLIC_API_BASE_URL=http://103.194.228.68:3552/v1/api/

# Firebase Configuration (Optional - if using Firebase)
EXPO_PUBLIC_FIREBASE_API_KEY=your_firebase_api_key_here
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=your_firebase_auth_domain_here
EXPO_PUBLIC_FIREBASE_PROJECT_ID=your_firebase_project_id_here
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=your_firebase_storage_bucket_here
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your_firebase_messaging_sender_id_here
EXPO_PUBLIC_FIREBASE_APP_ID=your_firebase_app_id_here

# Google Sign-In Configuration
EXPO_PUBLIC_GOOGLE_CLIENT_ID=your_google_client_id_here
EXPO_PUBLIC_GOOGLE_CLIENT_SECRET=your_google_client_secret_here

# Razorpay Configuration (Payment Gateway)
EXPO_PUBLIC_RAZORPAY_KEY_ID=your_razorpay_key_id_here
EXPO_PUBLIC_RAZORPAY_KEY_SECRET=your_razorpay_key_secret_here

# AWS S3 Configuration (Media Storage)
EXPO_PUBLIC_AWS_ACCESS_KEY_ID=your_aws_access_key_here
EXPO_PUBLIC_AWS_SECRET_ACCESS_KEY=your_aws_secret_key_here
EXPO_PUBLIC_AWS_REGION=ap-south-1
EXPO_PUBLIC_AWS_S3_BUCKET=your_s3_bucket_name_here

# Sentry Configuration (Error Tracking)
EXPO_PUBLIC_SENTRY_DSN=your_sentry_dsn_here

# Environment
EXPO_PUBLIC_ENV=production

# App Version
EXPO_PUBLIC_APP_VERSION=1.0.0
