# ✅ KIRO: Created by kiro - EAS Build Ignore Configuration for Mobile App
# Specifies files and directories to exclude from EAS builds to reduce build size and time

# ==================== DEPENDENCIES ====================
node_modules/
.pnp
.pnp.js
yarn.lock
package-lock.json

# ==================== IDE & EDITORS ====================
.vscode/
.idea/
*.swp
*.swo
*~
*.sublime-project
*.sublime-workspace
.DS_Store
Thumbs.db

# ==================== GIT ====================
.git/
.gitignore
.gitattributes
.github/

# ==================== BUILD ARTIFACTS ====================
build/
dist/
.next/
out/
.expo/
.expo-shared/
android/app/build/
android/.gradle/
ios/Pods/
ios/Podfile.lock

# ✅ KIRO: Edit by kiro - Aggressive exclusions to reduce EAS build size
# Remove entire android build directories
android/app/intermediates/
android/app/.cxx/
android/.gradle/
android/build/

# Remove iOS build artifacts
ios/Pods/
ios/build/
ios/.symlinks/
ios/Flutter/Flutter.framework/
ios/Flutter/Flutter.podspec

# Remove gradle wrapper
android/gradle/wrapper/gradle-*.jar

# Remove large node_modules subdirectories
node_modules/.bin/
node_modules/.cache/
node_modules/*/node_modules/
node_modules/*/.git/
node_modules/*/test/
node_modules/*/tests/
node_modules/*/example/
node_modules/*/examples/
node_modules/*/.github/

# ==================== TESTING ====================
coverage/
.nyc_output/
__tests__/
*.test.js
*.test.ts
*.test.tsx
jest.config.js

# ==================== LOGS ====================
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
expo-output.log

# ==================== TEMPORARY FILES ====================
*.tmp
.cache/
.turbo/
*.bak
*.swp
.DS_Store

# ==================== DOCUMENTATION ====================
*.md
docs/
README.md
CHANGELOG.md

# ==================== CI/CD ====================
.circleci/
.gitlab-ci.yml
.travis.yml

# ==================== MISC ====================
*.pem
*.key
.env.local
.env.*.local
debug.keystore

# ==================== ANALYSIS & REPORTS ====================
COMPLETE_ANALYSIS_REPORT.md
FINAL_FIX_REPORT.md
ERROR_FIX_REPORT.md
FIXES_SUMMARY.md
*.txt
PERCENTAGE_BREAKDOWN.txt

# ✅ KIRO: Edit by kiro - Exclude EAS archive check folder
eas-archive-check/

# ==================== KIRO: Additional exclusions to reduce build size ====================
# Expo cache
.expo-shared/
.expo/cache/

# Android build cache
android/.gradle/
android/app/build/
android/build/

# iOS build cache
ios/Pods/
ios/build/

# Node modules cache
node_modules/.cache/
node_modules/.bin/

# Turbo cache
.turbo/cache/

# Metro cache
.metro-cache/

# Yarn/npm cache
.yarn/cache/
.npm/

# Patch files
patches/

# Backup files
*.backup
*.old
*.bak
