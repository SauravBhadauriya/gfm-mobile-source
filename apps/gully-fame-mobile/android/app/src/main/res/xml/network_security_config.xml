<?xml version="1.0" encoding="utf-8"?>
<!-- ✅ KIRO: Network Security Config - Allows HTTP traffic to backend server -->
<!-- This file is required for Android 9+ to allow cleartext (HTTP) traffic -->
<!-- Reference: https://developer.android.com/training/articles/security-config -->
<network-security-config>
  <!-- ✅ KIRO: Allow cleartext traffic to backend API server -->
  <domain-config cleartextTrafficPermitted="true">
    <domain includeSubdomains="true">103.194.228.68</domain>
  </domain-config>

  <!-- ✅ KIRO: Allow cleartext traffic to localhost for development -->
  <domain-config cleartextTrafficPermitted="true">
    <domain includeSubdomains="true">localhost</domain>
    <domain includeSubdomains="true">127.0.0.1</domain>
  </domain-config>

  <!-- Default policy for all other domains - HTTPS only (secure) -->
  <domain-config cleartextTrafficPermitted="false">
    <domain includeSubdomains="true">example.com</domain>
  </domain-config>
</network-security-config>
